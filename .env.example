# Copy this file to .env and fill with your actual values
# NEVER commit .env file to version control!

# MongoDB Atlas Connection String
# Get this from: https://account.mongodb.com/account/login
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/database
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.fps9an5.mongodb.net/marketplace?retryWrites=true&w=majority

# JWT Secret Key (min 32 characters recommended)
# Keep this secure! Use a strong random string
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_recommended

# Application Profile (local or prod)
SPRING_PROFILES_ACTIVE=local
